FLASK_ENV=production
SECRET_KEY=change-this-to-a-long-random-string
JWT_SECRET_KEY=change-this-to-another-long-random-string

# MongoDB Atlas — get from cloud.mongodb.com
MONGO_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/bangladesh_newspaper?retryWrites=true&w=majority

# Resend SMTP — get from resend.com
MAIL_SERVER=smtp.resend.com
MAIL_PORT=465
MAIL_USE_TLS=False
MAIL_USERNAME=resend
MAIL_PASSWORD=re_your_resend_api_key
MAIL_DEFAULT_SENDER=news@yourdomain.com

# OpenAI (for article translation)
OPENAI_API_KEY=sk-your-openai-key

# Frontend URL (used in invitation/newsletter email links)
FRONTEND_URL=https://bgn-frontend.onrender.com

UPLOAD_FOLDER=app/static/uploads
MAX_CONTENT_LENGTH=16777216

# Set to true on Render/production to store uploads in MongoDB GridFS
# (avoids losing files on redeploy due to ephemeral filesystem)
USE_GRIDFS=false
